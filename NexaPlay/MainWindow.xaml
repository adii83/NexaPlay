<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexaPlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NexaPlay">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="240" MaxWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{ThemeResource NexaSidebarBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + Branding -->
                <Border Grid.Row="0" Padding="20,28,20,20">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <!-- Logo mark -->
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#8B7CF8">
                                <FontIcon Glyph="&#xE7FC;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="16"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="NexaPlay"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource NexaTextPrimaryBrush}"/>
                                <TextBlock Text="Game Manager"
                                           FontSize="10"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="0" Margin="0,4,0,12">

                        <!-- Section label: MENU -->
                        <TextBlock Text="MENU"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"/>

                        <!-- Home -->
                        <RadioButton x:Name="NavHome"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="True"
                                     Checked="OnNavChecked"
                                     Tag="&#xE80F;">
                            <TextBlock x:Name="LblHome"
                                       Text="Home"
                                       Style="{StaticResource NavLabelActiveStyle}"/>
                        </RadioButton>

                        <!-- Games -->
                        <RadioButton x:Name="NavGames"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE7FC;">
                            <TextBlock x:Name="LblGames"
                                       Text="Games"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Library -->
                        <RadioButton x:Name="NavLibrary"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE8F1;">
                            <TextBlock x:Name="LblLibrary"
                                       Text="Library"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Fix Games -->
                        <RadioButton x:Name="NavFixGames"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE90F;">
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="LblFixGames"
                                           Text="Fix Games"
                                           Style="{StaticResource NavLabelStyle}"/>
                                <Border CornerRadius="4" Padding="5,1"
                                        Background="#8B7CF828"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="NEW"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="#8B7CF8"
                                               CharacterSpacing="60"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <!-- Divider -->
                        <Border Height="1"
                                Background="{ThemeResource NexaBorderBrush}"
                                Margin="16,12,16,12"/>

                        <!-- Section label: ACCOUNT -->
                        <TextBlock Text="ACCOUNT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"/>

                        <!-- Settings -->
                        <RadioButton x:Name="NavSettings"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE713;">
                            <TextBlock x:Name="LblSettings"
                                       Text="Settings"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: version + license badge -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource NexaBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="NexaPlay"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{ThemeResource NexaTextSecondaryBrush}"/>
                            <TextBlock Text="v1.0.0 • Windows"
                                       FontSize="10"
                                       Foreground="{ThemeResource NexaTextMutedBrush}"/>
                        </StackPanel>
                        <!-- License Badge -->
                        <Border Grid.Column="1" CornerRadius="6"
                                Padding="8,4"
                                Background="#22C55E18">
                            <TextBlock Text="PRO"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="#22C55E"
                                       CharacterSpacing="80"/>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    BorderBrush="{ThemeResource NexaBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Page Title -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="Home"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Actions: Search + Update -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">

                        <!-- Search box -->
                        <Border CornerRadius="8"
                                Background="#FFFFFF08"
                                BorderBrush="{ThemeResource NexaBorderBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Width="220"
                                Height="36">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE721;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="13"
                                          Foreground="{ThemeResource NexaTextMutedBrush}"
                                          Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1"
                                         PlaceholderText="Search games..."
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                         PlaceholderForeground="{ThemeResource NexaTextMutedBrush}"
                                         FontSize="13"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Update button -->
                        <Button x:Name="UpdateButton"
                                Width="36" Height="36"
                                Padding="0"
                                CornerRadius="8"
                                Background="#FFFFFF08"
                                BorderBrush="{ThemeResource NexaBorderBrush}"
                                BorderThickness="1"
                                ToolTipService.ToolTip="Check for updates">
                            <FontIcon Glyph="&#xE72C;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="14"
                                      Foreground="{ThemeResource NexaTextSecondaryBrush}"/>
                        </Button>

                        <!-- Notification dot button -->
                        <Button x:Name="NotifButton"
                                Width="36" Height="36"
                                Padding="0"
                                CornerRadius="8"
                                Background="#FFFFFF08"
                                BorderBrush="{ThemeResource NexaBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <FontIcon Glyph="&#xEA8F;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource NexaTextSecondaryBrush}"/>
                                <!-- Notif dot -->
                                <Ellipse Width="7" Height="7"
                                         Fill="#8B7CF8"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,2,2,0"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content Frame -->
            <Frame x:Name="ContentFrame"
                   Grid.Row="1"/>

        </Grid>
    </Grid>
</Window>

