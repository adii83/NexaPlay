<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexaPlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NexaPlay">

    <!-- Removed MicaBackdrop per user request for solid black -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="WindowTopRow" Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             CUSTOM TITLE BAR
        ══════════════════════════════════════════════════════ -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource NexaSidebarBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Image Width="20" Height="20">
                        <Image.Source>
                            <SvgImageSource RasterizePixelHeight="40" RasterizePixelWidth="40" UriSource="ms-appx:///Assets/logo.svg"/>
                        </Image.Source>
                    </Image>
                    <Image Height="12" Margin="0,2,0,0">
                        <Image.Source>
                            <SvgImageSource RasterizePixelHeight="24" UriSource="ms-appx:///Assets/logo_text.svg"/>
                        </Image.Source>
                    </Image>
                </StackPanel>
            </Grid>
        </Border>

        <SplitView x:Name="RootSplitView"
                   Grid.Row="1"
                   DisplayMode="CompactInline"
                   CompactPaneLength="68"
                   OpenPaneLength="200"
                   IsPaneOpen="False"
                   PaneBackground="Transparent">
            
            <SplitView.Pane>

        <!-- ══════════════════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════════════════ -->
        <Border x:Name="SidebarShell"
                Background="{ThemeResource NexaSidebarBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}"
                BorderThickness="0,0,1,0"
                HorizontalAlignment="Stretch"
                PointerEntered="Sidebar_PointerEntered"
                PointerExited="Sidebar_PointerExited">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Padding for Nav -->
                <Border Grid.Row="0" Height="20" />

                <!-- Nav Items -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavItemsPanel" Width="68" HorizontalAlignment="Left" Spacing="0" Margin="0,4,0,12">

                        <!-- Section label: MENU -->
                        <TextBlock x:Name="MenuHeader"
                                   Text="MENU"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"
                                   Visibility="Collapsed"/>

                        <!-- Home -->
                        <RadioButton x:Name="NavHome"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="True"
                                     Checked="OnNavChecked"
                                     Tag="&#xE80F;">
                            <TextBlock x:Name="LblHome"
                                       Text="Home"
                                       Style="{StaticResource NavLabelActiveStyle}"/>
                        </RadioButton>

                        <!-- Games -->
                        <RadioButton x:Name="NavGames"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE7FC;">
                            <TextBlock x:Name="LblGames"
                                       Text="Games"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Library -->
                        <RadioButton x:Name="NavLibrary"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE8F1;">
                            <TextBlock x:Name="LblLibrary"
                                       Text="Library"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Fix Games -->
                        <RadioButton x:Name="NavBypass"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE90F;">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblBypassGames"
                                           Grid.Column="0"
                                           Text="Bypass"
                                           Style="{StaticResource NavLabelStyle}"/>
                                <FontIcon x:Name="BypassChevron"
                                          Grid.Column="1"
                                          Glyph="&#xE70D;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="12"
                                          Margin="8,0,12,0"
                                          Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                            </Grid>
                        </RadioButton>
                        
                        <!-- Bypass Submenu -->
                        <StackPanel x:Name="BypassSubmenuPanel"
                                    Margin="36,0,12,12"
                                    Spacing="2"
                                    Visibility="Collapsed">
                                <Button x:Name="BypassSubmenuThirdParty"
                                        Click="OnBypassSubmenuClicked"
                                        Tag="all"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="#1AFFFFFF"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                        FontSize="12"
                                        FontWeight="Medium">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE774;"
                                                  FontFamily="Segoe Fluent Icons"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                        <TextBlock Text="3rd Party" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BypassSubmenuSteam"
                                        Click="OnBypassSubmenuClicked"
                                        Tag="steam-sharing"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                        FontSize="12"
                                        FontWeight="Medium">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE77B;"
                                                  FontFamily="Segoe Fluent Icons"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                                        <TextBlock Text="Steam Sharing" />
                                    </StackPanel>
                                </Button>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Height="1"
                                Background="{ThemeResource NexaBorderBrush}"
                                Margin="16,12,16,12"/>

                        <!-- Section label: ACCOUNT -->
                        <TextBlock x:Name="AccountHeader"
                                   Text="ACCOUNT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"
                                   Visibility="Collapsed"/>

                        <!-- Settings -->
                        <RadioButton x:Name="NavSettings"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE713;">
                            <TextBlock x:Name="LblSettings"
                                       Text="Settings"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: version + license badge -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource NexaBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <Grid x:Name="VersionGrid" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="NexaPlay"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{ThemeResource NexaTextSecondaryBrush}"/>
                            <TextBlock Text="v1.0.0 • Windows"
                                       FontSize="10"
                                       Foreground="{ThemeResource NexaTextMutedBrush}"/>
                        </StackPanel>
                        <!-- License Badge -->
                        <Border Grid.Column="1" CornerRadius="6"
                                Padding="8,4"
                                Background="#1822C55E">
                            <TextBlock Text="PRO"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="#22C55E"
                                       CharacterSpacing="80"/>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>
            </SplitView.Pane>

            <SplitView.Content>

        <!-- ══════════════════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════════════════ -->
            <Grid BorderBrush="#232323"
              BorderThickness="1,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ContentTopBarRow" Height="0"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border x:Name="PageTopBar" Visibility="Collapsed"
                    Grid.Row="0"
                    Background="#080808"
                    BorderBrush="{ThemeResource NexaBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Page Title -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="Home"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Actions: Search + Update -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">

                        <!-- Search box (Disembunyikan karena tidak digunakan di halaman Home) -->
                        <Border CornerRadius="4"
                                Background="{ThemeResource NexaSurfaceElevatedBrush}"
                                BorderBrush="{ThemeResource NexaBorderBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Width="220"
                                Height="32"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE721;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="13"
                                          Foreground="{ThemeResource NexaTextMutedBrush}"
                                          Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1"
                                         PlaceholderText="Search..."
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                         PlaceholderForeground="{ThemeResource NexaTextMutedBrush}"
                                         FontSize="13"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>



                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content Frame -->
            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"/>

            <Border x:Name="StartupOverlay"
                    Grid.RowSpan="2"
                    Background="#080808"
                    Visibility="Collapsed">
                <Border Width="400"
                        Padding="32,40,32,40"
                        CornerRadius="16"
                        Background="#121212"
                        BorderBrush="#1F1F1F"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="0">
                        <!-- NexaPlay Premium Logo -->
                        <Image Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Image.Source>
                                <SvgImageSource RasterizePixelHeight="96" RasterizePixelWidth="96" UriSource="ms-appx:///Assets/logo.svg"/>
                            </Image.Source>
                        </Image>

                        <!-- Title/Message (human language, only visible on cold boot) -->
                        <TextBlock x:Name="StartupTitleText"
                                   Text="Menyiapkan NexaPlay"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"
                                   Visibility="Collapsed" />
                        
                        <TextBlock x:Name="StartupStatusText"
                                   Text="Mohon tunggu sebentar..."
                                   FontSize="13"
                                   Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"
                                   Visibility="Collapsed" />

                        <!-- Sleek Progress Bar -->
                        <ProgressBar x:Name="StartupProgressBar"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Height="4"
                                     CornerRadius="2"
                                     Background="#1F1F1F"
                                     Foreground="{ThemeResource NexaAccentBrush}"
                                     HorizontalAlignment="Stretch" />

                        <!-- Percentage text (human language, only visible on cold boot) -->
                        <TextBlock x:Name="StartupPercentText"
                                   Text="0%"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
            </SplitView.Content>
        </SplitView>

        <!-- ══════════════════════════════════════════════════════
             LICENSE ACTIVATION OVERLAY
        ══════════════════════════════════════════════════════ -->
        <Grid x:Name="LicenseOverlay" Grid.Row="1" Background="#080808" Visibility="Collapsed">
            <Grid Width="460" Background="#111111" CornerRadius="16" BorderBrush="#222222" BorderThickness="1" Padding="40,48" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: Logo & Title -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,32">
                    <Image Width="64" Height="64">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/logo.svg"/>
                        </Image.Source>
                    </Image>
                    <Image Height="24" Margin="0,4,0,0">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/logo_text.svg"/>
                        </Image.Source>
                    </Image>
                    <TextBlock Text="Masukkan License Key Anda" FontSize="14" Foreground="#888888" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Body: Input -->
                <StackPanel Grid.Row="1" Spacing="12">
                    <TextBlock Text="License Key" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE"/>
                    <TextBox x:Name="LicenseKeyBox"
                             PlaceholderText="Masukkan license key Anda"
                             BorderThickness="1"
                             BorderBrush="#333333"
                             Background="#1A1A1A"
                             Foreground="#FFFFFF"
                             PlaceholderForeground="#666666"
                             FontSize="14"
                             Padding="16,14"
                             CornerRadius="8"
                             CharacterCasing="Upper"/>
                    
                    <Border x:Name="LicenseStatusBorder" CornerRadius="6" Padding="12" Visibility="Collapsed" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <FontIcon x:Name="LicenseStatusIcon" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LicenseStatusText" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="340"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Action Button -->
                <Button x:Name="ActivateButton" Grid.Row="2" Margin="0,24,0,0" HorizontalAlignment="Stretch"
                        Background="#FFFFFF" Foreground="#000000" BorderThickness="0" CornerRadius="8" Padding="0,14" Click="OnActivateClicked">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#CCFFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#99FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonForeground" Color="#000000"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#000000"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#000000"/>
                    </Button.Resources>
                    <Grid>
                        <TextBlock x:Name="LicenseBtnText" Text="Aktivasi" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" />
                        <ProgressRing x:Name="LicenseLoadingRing" IsActive="False" Visibility="Collapsed" Width="20" Height="20" Foreground="#000000" HorizontalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Margin="0,32,0,0" Spacing="16">
                    <Rectangle Height="1" Fill="#222222" HorizontalAlignment="Stretch" />
                    <TextBlock Text="License key Anda akan terikat dengan perangkat ini.&#x0a;Satu license key hanya bisa digunakan di satu perangkat."
                               FontSize="11" Foreground="#666666" TextAlignment="Center" LineHeight="18" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             VALIDATING LICENSE OVERLAY
        ══════════════════════════════════════════════════════ -->
        <Grid x:Name="ValidatingLicenseOverlay" Grid.Row="1" Visibility="Collapsed" Canvas.ZIndex="150" Background="#111111">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <Image Width="64" Height="64">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/logo.svg"/>
                        </Image.Source>
                    </Image>
                </StackPanel>
                
                <TextBlock Text="Memvalidasi Lisensi..." FontSize="24" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                
                <StackPanel Spacing="16" HorizontalAlignment="Center" MaxWidth="400">
                    <ProgressRing x:Name="ValidationProgressRing" IsActive="True" Foreground="#FFFFFF" Width="40" Height="40" HorizontalAlignment="Center" />
                    <TextBlock x:Name="ValidationStatusText" Text="Menghubungkan ke server..." Foreground="#A0A0A0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
                
                <!-- Error Panel -->
                <StackPanel x:Name="ValidationErrorPanel" Visibility="Collapsed" Spacing="16" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Border x:Name="ValidationErrorBorder" Background="#18EF4444" BorderBrush="#33EF4444" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="ValidationErrorIcon" Glyph="&#xEA39;" FontFamily="Segoe Fluent Icons" Foreground="#EF4444" VerticalAlignment="Center" />
                            <TextBlock x:Name="ValidationErrorMessage" Text="Koneksi terputus." Foreground="#EF4444" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="ValidationRetryButton" Content="Coba Lagi" Click="OnValidationRetryClicked" Background="#FFFFFF" Foreground="#000000" FontWeight="SemiBold" CornerRadius="4" Padding="24,10" HorizontalAlignment="Center" />
                    <Button x:Name="ValidationEnterKeyButton" Content="Masukkan License Key Baru" Click="OnValidationEnterKeyClicked" Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
