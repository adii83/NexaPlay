<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexaPlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NexaPlay">

    <!-- Removed MicaBackdrop per user request for solid black -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <SplitView x:Name="RootSplitView"
                   DisplayMode="CompactInline"
                   CompactPaneLength="68"
                   OpenPaneLength="200"
                   IsPaneOpen="False"
                   PaneBackground="Transparent">
            
            <SplitView.Pane>

        <!-- ══════════════════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════════════════ -->
        <Border Background="{ThemeResource NexaSidebarBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}"
                BorderThickness="0,0,1,0"
                HorizontalAlignment="Stretch"
                PointerEntered="Sidebar_PointerEntered"
                PointerExited="Sidebar_PointerExited">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + Branding -->
                <Border Grid.Row="0" Padding="14,28,14,20">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <!-- Logo mark -->
                            <Image Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.Source>
                                    <SvgImageSource RasterizePixelHeight="64" RasterizePixelWidth="64" UriSource="ms-appx:///Assets/logo.svg"/>
                                </Image.Source>
                            </Image>
                            <StackPanel x:Name="AppTitlePanel" VerticalAlignment="Center" Spacing="0" Visibility="Collapsed">
                                <Image Height="16" HorizontalAlignment="Left" Margin="4,0,0,0">
                                    <Image.Source>
                                        <SvgImageSource RasterizePixelHeight="32" UriSource="ms-appx:///Assets/logo_text.svg"/>
                                    </Image.Source>
                                </Image>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavItemsPanel" Width="68" HorizontalAlignment="Left" Spacing="0" Margin="0,4,0,12">

                        <!-- Section label: MENU -->
                        <TextBlock x:Name="MenuHeader"
                                   Text="MENU"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"
                                   Visibility="Collapsed"/>

                        <!-- Home -->
                        <RadioButton x:Name="NavHome"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="True"
                                     Checked="OnNavChecked"
                                     Tag="&#xE80F;">
                            <TextBlock x:Name="LblHome"
                                       Text="Home"
                                       Style="{StaticResource NavLabelActiveStyle}"/>
                        </RadioButton>

                        <!-- Games -->
                        <RadioButton x:Name="NavGames"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE7FC;">
                            <TextBlock x:Name="LblGames"
                                       Text="Games"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Library -->
                        <RadioButton x:Name="NavLibrary"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE8F1;">
                            <TextBlock x:Name="LblLibrary"
                                       Text="Library"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                        <!-- Fix Games -->
                        <RadioButton x:Name="NavBypass"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE90F;">
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="LblBypassGames"
                                           Text="Bypass"
                                           Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Divider -->
                        <Border Height="1"
                                Background="{ThemeResource NexaBorderBrush}"
                                Margin="16,12,16,12"/>

                        <!-- Section label: ACCOUNT -->
                        <TextBlock x:Name="AccountHeader"
                                   Text="ACCOUNT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextMutedBrush}"
                                   Margin="24,0,0,8"
                                   CharacterSpacing="120"
                                   Visibility="Collapsed"/>

                        <!-- Settings -->
                        <RadioButton x:Name="NavSettings"
                                     Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="&#xE713;">
                            <TextBlock x:Name="LblSettings"
                                       Text="Settings"
                                       Style="{StaticResource NavLabelStyle}"/>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: version + license badge -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource NexaBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <Grid x:Name="VersionGrid" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="NexaPlay"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{ThemeResource NexaTextSecondaryBrush}"/>
                            <TextBlock Text="v1.0.0 • Windows"
                                       FontSize="10"
                                       Foreground="{ThemeResource NexaTextMutedBrush}"/>
                        </StackPanel>
                        <!-- License Badge -->
                        <Border Grid.Column="1" CornerRadius="6"
                                Padding="8,4"
                                Background="#1822C55E">
                            <TextBlock Text="PRO"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="#22C55E"
                                       CharacterSpacing="80"/>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>
            </SplitView.Pane>

            <SplitView.Content>

        <!-- ══════════════════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    BorderBrush="{ThemeResource NexaBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Page Title -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="Home"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Actions: Search + Update -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">

                        <!-- Search box -->
                        <Border CornerRadius="4"
                                Background="{ThemeResource NexaSurfaceElevatedBrush}"
                                BorderBrush="{ThemeResource NexaBorderBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Width="220"
                                Height="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE721;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="13"
                                          Foreground="{ThemeResource NexaTextMutedBrush}"
                                          Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1"
                                         PlaceholderText="Search..."
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                         PlaceholderForeground="{ThemeResource NexaTextMutedBrush}"
                                         FontSize="13"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>



                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content Frame -->
            <Frame x:Name="ContentFrame"
                   Grid.Row="1"/>

        </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>

