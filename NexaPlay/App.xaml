<Application
    x:Class="NexaPlay.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- NexaPlay Brand Colors -->
                    <SolidColorBrush x:Key="NexaAccentBrush"          Color="#8B7CF8"/>
                    <SolidColorBrush x:Key="NexaAccentHoverBrush"      Color="#A99DF9"/>
                    <SolidColorBrush x:Key="NexaAccentDimBrush"        Color="#8B7CF820"/>
                    <SolidColorBrush x:Key="NexaAccentDim2Brush"       Color="#8B7CF840"/>
                    <SolidColorBrush x:Key="NexaSidebarBrush"          Color="#0C0C0C"/>
                    <SolidColorBrush x:Key="NexaSurfaceBrush"          Color="#111111"/>
                    <SolidColorBrush x:Key="NexaSurfaceElevatedBrush"  Color="#191919"/>
                    <SolidColorBrush x:Key="NexaSurfaceHoverBrush"     Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="NexaBorderBrush"           Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="NexaBorderSubtleBrush"     Color="#161616"/>
                    <SolidColorBrush x:Key="NexaTextPrimaryBrush"      Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="NexaTextSecondaryBrush"    Color="#8A8A8A"/>
                    <SolidColorBrush x:Key="NexaTextMutedBrush"        Color="#4A4A4A"/>
                    <SolidColorBrush x:Key="NexaSuccessBrush"          Color="#22C55E"/>
                    <SolidColorBrush x:Key="NexaWarningBrush"          Color="#F59E0B"/>
                    <SolidColorBrush x:Key="NexaDangerBrush"           Color="#EF4444"/>
                    <SolidColorBrush x:Key="NexaBlueBrush"             Color="#3B82F6"/>

                    <!-- Override WinUI system colors to match our theme -->
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#0F0F0F"/>
                    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#111111"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Nav Item RadioButton Style -->
            <Style x:Key="NavItemStyle" TargetType="RadioButton">
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment"   Value="Center"/>
                <Setter Property="Height"                     Value="44"/>
                <Setter Property="Margin"                     Value="8,2,8,2"/>
                <Setter Property="Padding"                    Value="0"/>
                <Setter Property="Background"                 Value="Transparent"/>
                <Setter Property="BorderThickness"            Value="0"/>
                <Setter Property="CornerRadius"               Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid x:Name="Root" CornerRadius="8" Height="44">
                                <!-- Hover / selected background -->
                                <Border x:Name="BgBorder"
                                        Background="Transparent"
                                        CornerRadius="8"/>
                                <!-- Left accent bar -->
                                <Rectangle x:Name="AccentBar"
                                           Width="3" HorizontalAlignment="Left"
                                           RadiusX="2" RadiusY="2"
                                           Fill="#8B7CF8" Opacity="0"/>
                                <!-- Content row: icon + label -->
                                <Grid Margin="16,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Icon slot — uses Tag -->
                                    <Viewbox x:Name="IconBox"
                                             Grid.Column="0"
                                             Width="18" Height="18"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <FontIcon x:Name="IconElement" Glyph="{TemplateBinding Tag}" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#4A4A4A" />
                                    </Viewbox>
                                    <!-- Label slot — uses Content -->
                                    <ContentPresenter x:Name="LabelPresenter"
                                                      Grid.Column="2"
                                                      Content="{TemplateBinding Content}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="BgBorder.Background" Value="#FFFFFF0D"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="BgBorder.Background" Value="#FFFFFF18"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked">
                                            <VisualState.Setters>
                                                <!-- Icon muted when not active -->
                                                <Setter Target="IconElement.Foreground" Value="#4A4A4A"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="AccentBar.Opacity"   Value="1"/>
                                                <Setter Target="BgBorder.Background" Value="#8B7CF818"/>
                                                <!-- Icon bright when active -->
                                                <Setter Target="IconElement.Foreground" Value="#8B7CF8"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Indeterminate"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nav icon FontIcon style — default muted, active state handled by template -->
            <Style x:Key="NavIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
                <Setter Property="FontSize"   Value="16"/>
                <Setter Property="Foreground"  Value="#4A4A4A"/>
            </Style>

            <!-- Nav label TextBlock style — active color set via code-behind trigger -->
            <Style x:Key="NavLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="13.5"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Foreground"  Value="#5A5A5A"/>
            </Style>

            <!-- Nav label ACTIVE style -->
            <Style x:Key="NavLabelActiveStyle" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="13.5"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground"  Value="#F5F5F5"/>
            </Style>

            <!-- Badge pill style -->
            <Style x:Key="BadgePillStyle" TargetType="Border">
                <Setter Property="CornerRadius"  Value="4"/>
                <Setter Property="Padding"       Value="6,2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Card surface style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background"    Value="#161616"/>
                <Setter Property="CornerRadius"  Value="12"/>
                <Setter Property="BorderBrush"   Value="#1E1E1E"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>



