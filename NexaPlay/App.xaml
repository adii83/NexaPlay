<Application
    x:Class="NexaPlay.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- NexaPlay Brand Colors (Enterprise Clean & Neutral) -->
                    <SolidColorBrush x:Key="NexaAccentBrush"           Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="NexaAccentHoverBrush"      Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="NexaAccentDimBrush"        Color="#1AFFFFFF"/>
                    <SolidColorBrush x:Key="NexaAccentDim2Brush"       Color="#33FFFFFF"/>
                    <SolidColorBrush x:Key="NexaSidebarBrush"          Color="#080808"/>
                    <SolidColorBrush x:Key="NexaSurfaceBrush"          Color="#080808"/>
                    <SolidColorBrush x:Key="NexaSurfaceElevatedBrush"  Color="#121212"/>
                    <SolidColorBrush x:Key="NexaSurfaceHoverBrush"     Color="#1A1A1A"/>
                    <!-- Card surfaces -->
                    <SolidColorBrush x:Key="NexaCardBrush"             Color="#101010"/>
                    <SolidColorBrush x:Key="NexaCardElevatedBrush"     Color="#161616"/>
                    <SolidColorBrush x:Key="NexaCardBorderBrush"       Color="#28FFFFFF"/>
                    <SolidColorBrush x:Key="NexaBorderBrush"           Color="#1FFFFFFF"/>
                    <SolidColorBrush x:Key="NexaBorderSubtleBrush"     Color="#0FFFFFFF"/>
                    <SolidColorBrush x:Key="NexaTextPrimaryBrush"      Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="NexaTextSecondaryBrush"    Color="#A0A0A0"/>
                    <SolidColorBrush x:Key="NexaTextMutedBrush"        Color="#666666"/>
                    <SolidColorBrush x:Key="NexaSuccessBrush"          Color="#22C55E"/>
                    <SolidColorBrush x:Key="NexaWarningBrush"          Color="#F59E0B"/>
                    <SolidColorBrush x:Key="NexaDangerBrush"           Color="#EF4444"/>
                    <SolidColorBrush x:Key="NexaBlueBrush"             Color="#3B82F6"/>

                    <!-- Override WinUI system colors to match our theme -->
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#080808"/>
                    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#0A0A0A"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Nav Item RadioButton Style -->
            <Style x:Key="NavItemStyle" TargetType="RadioButton">
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment"   Value="Center"/>
                <Setter Property="Height"                     Value="44"/>
                <Setter Property="Margin"                     Value="8,2,8,2"/>
                <Setter Property="Padding"                    Value="0"/>
                <Setter Property="Background"                 Value="Transparent"/>
                <Setter Property="BorderThickness"            Value="0"/>
                <Setter Property="CornerRadius"               Value="8"/>
                <Setter Property="UseSystemFocusVisuals"      Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid x:Name="Root" CornerRadius="8" Height="44">
                                <!-- Hover background -->
                                <Border x:Name="HoverBorder"
                                        Background="#0DFFFFFF"
                                        CornerRadius="8"
                                        Opacity="0"/>
                                <!-- Checked background (Glowing White) -->
                                <Border x:Name="CheckedBorder"
                                        Background="#0AFFFFFF"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Opacity="0">
                                    <!-- Left Indicator Pill -->
                                    <Border Width="3" Height="16" CornerRadius="1.5"
                                            Background="#FFFFFF"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                                </Border>
                                <!-- Pressed background -->
                                <Border x:Name="PressedBorder"
                                        Background="#18FFFFFF"
                                        CornerRadius="8"
                                        Opacity="0"/>
                                <!-- Accent bar removed in favor of solid pill background -->
                                <!-- Content row: icon + label -->
                                <Grid Margin="14,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Icon slot — uses Tag -->
                                    <Viewbox x:Name="IconBox"
                                             Grid.Column="0"
                                             Width="18" Height="18"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <FontIcon x:Name="IconElement" Glyph="{TemplateBinding Tag}" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                                    </Viewbox>
                                    <!-- Label slot — uses Content -->
                                    <ScrollViewer Grid.Column="1"
                                                  Margin="14,0,0,0"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  HorizontalScrollMode="Disabled"
                                                  VerticalScrollMode="Disabled">
                                        <ContentPresenter x:Name="LabelPresenter"
                                                          Content="{TemplateBinding Content}"
                                                          VerticalAlignment="Center"/>
                                    </ScrollViewer>
                                </Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="HoverBorder.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="PressedBorder.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked">
                                            <VisualState.Setters>
                                                <!-- Default colors handled by static resources -->
                                                <Setter Target="IconElement.Foreground" Value="{ThemeResource NexaTextSecondaryBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="CheckedBorder.Opacity" Value="1"/>
                                                <!-- Icon & text flip to white when active -->
                                                <Setter Target="IconElement.Foreground" Value="#FFFFFF"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Indeterminate"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nav icon FontIcon style — default secondary, active state handled by template -->
            <Style x:Key="NavIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
                <Setter Property="FontSize"   Value="16"/>
                <Setter Property="Foreground"  Value="{ThemeResource NexaTextSecondaryBrush}"/>
            </Style>

            <!-- Nav label TextBlock style — active color set via code-behind trigger -->
            <Style x:Key="NavLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="13.5"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground"  Value="{ThemeResource NexaTextSecondaryBrush}"/>
                <Setter Property="TextTrimming" Value="Clip"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>

            <!-- Nav label ACTIVE style -->
            <Style x:Key="NavLabelActiveStyle" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="13.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground"  Value="#FFFFFF"/>
                <Setter Property="TextTrimming" Value="Clip"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>

            <!-- Badge pill style -->
            <Style x:Key="BadgePillStyle" TargetType="Border">
                <Setter Property="CornerRadius"  Value="4"/>
                <Setter Property="Padding"       Value="6,2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Card surface style — border putih tipis samar sebagai pemisah dari background hitam -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background"      Value="{ThemeResource NexaCardBrush}"/>
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource NexaCardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="16"/>
            </Style>

            <!-- Card elevated — sedikit lebih terang untuk nested card -->
            <Style x:Key="CardElevatedStyle" TargetType="Border">
                <Setter Property="Background"      Value="{ThemeResource NexaCardElevatedBrush}"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource NexaCardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="12"/>
            </Style>

            <!-- Card flat — untuk item list dalam card -->
            <Style x:Key="CardItemStyle" TargetType="Border">
                <Setter Property="Background"      Value="#0CFFFFFF"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="BorderBrush"     Value="#12FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="12,10"/>
            </Style>

            <!--
                PopularGameCardStyle
                ─────────────────────────────────────────────────────────────
                Button container untuk card Popular Games di HomePage.
                Hover: scale naik tipis (1.03) + border putih lebih terang.
                Pressed: scale turun sedikit (0.98) untuk tactile feedback.
                Semua transisi pakai EasingFunction agar terasa smooth & premium.
                Tidak ada warna aksen — murni hitam/putih sesuai design system.
            -->
            <Style x:Key="PopularGameCardStyle" TargetType="Button">
                <Setter Property="Padding"          Value="0"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="VerticalAlignment"          Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
                <Setter Property="UseSystemFocusVisuals"      Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- RenderTransformOrigin="0.5,0.5" agar scale dari tengah card -->
                            <Grid x:Name="RootGrid"
                                  RenderTransformOrigin="0.5,0.5"
                                  Height="{TemplateBinding Height}"
                                  Width="{TemplateBinding Width}"
                                  CornerRadius="12">

                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>

                                <!-- Konten card (diteruskan dari ContentPresenter) -->
                                <ContentPresenter x:Name="ContentPresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>

                                <!--
                                    Hover lighting overlay — border putih lebih terang saat hover.
                                    Opacity 0 di normal, naik ke 1 saat PointerOver.
                                    Ini yang memberi efek "glowing edge" premium.
                                -->
                                <Border x:Name="HoverBorderOverlay"
                                        CornerRadius="12"
                                        BorderThickness="2.2"
                                        BorderBrush="#CCFFFFFF"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>

                                <!--
                                    Pressed overlay — flash putih sangat tipis saat klik.
                                -->
                                <Border x:Name="PressedOverlay"
                                        CornerRadius="12"
                                        Background="#12FFFFFF"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">

                                        <VisualStateGroup.Transitions>
                                            <!-- Transisi masuk/keluar hover — smooth 180ms -->
                                            <VisualTransition From="Normal" To="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1.008" Duration="0:0:0.16">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1.008" Duration="0:0:0.16">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="HoverBorderOverlay"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="1" Duration="0:0:0.16">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </VisualTransition>
                                            <VisualTransition From="PointerOver" To="Normal">
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1.0" Duration="0:0:0.18">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1.0" Duration="0:0:0.18">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="HoverBorderOverlay"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0" Duration="0:0:0.18">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </VisualTransition>
                                            <VisualTransition From="PointerOver" To="Pressed">
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="0.994" Duration="0:0:0.07">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="0.994" Duration="0:0:0.07">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="PressedOverlay"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0.7" Duration="0:0:0.07"/>
                                                </Storyboard>
                                            </VisualTransition>
                                            <VisualTransition From="Pressed" To="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1.008" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CardScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1.008" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="PressedOverlay"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0" Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </VisualTransition>
                                        </VisualStateGroup.Transitions>

                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="CardScale.ScaleX"          Value="1.008"/>
                                                <Setter Target="CardScale.ScaleY"          Value="1.008"/>
                                                <Setter Target="HoverBorderOverlay.Opacity" Value="1"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="CardScale.ScaleX"    Value="0.994"/>
                                                <Setter Target="CardScale.ScaleY"    Value="0.994"/>
                                                <Setter Target="PressedOverlay.Opacity" Value="0.7"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>

                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
