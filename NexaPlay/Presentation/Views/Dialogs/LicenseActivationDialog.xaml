<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NexaPlay.Presentation.Views.Dialogs.LicenseActivationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title=""
    PrimaryButtonText="Activate"
    CloseButtonText="Skip"
    DefaultButton="Primary"
    PrimaryButtonClick="OnActivateClicked">

    <ContentDialog.Resources>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
    </ContentDialog.Resources>

    <Grid Width="420">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,20"
                Background="#0F0F0F">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="#8B7CF8">
                        <FontIcon Glyph="&#xE734;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16" Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Activate NexaPlay"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Enter your license key to unlock all features"
                                   FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Spacing="16" Padding="28,20">

            <!-- Key input -->
            <StackPanel Spacing="8">
                <TextBlock Text="License Key"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#A0A0A0"/>
                <Border CornerRadius="10"
                        BorderBrush="#2A2A2A" BorderThickness="1"
                        Background="#161616">
                    <TextBox x:Name="LicenseKeyBox"
                             PlaceholderText="NEXAP-XXXXX-XXXXX-XXXXX-XXXXX"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="White"
                             PlaceholderForeground="#505050"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             Padding="14,12"
                             CharacterCasing="Upper"/>
                </Border>
            </StackPanel>

            <!-- Status message -->
            <Border x:Name="StatusBorder"
                    CornerRadius="8" Padding="12,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon x:Name="StatusIcon"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="14"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               FontSize="12" TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               MaxWidth="340"/>
                </StackPanel>
            </Border>

            <!-- Progress ring -->
            <StackPanel x:Name="LoadingPanel"
                        Orientation="Horizontal" Spacing="12"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center">
                <ProgressRing IsActive="True" Width="20" Height="20"
                              Foreground="#8B7CF8"/>
                <TextBlock Text="Validating license..."
                           FontSize="12" Foreground="#808080"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>

        <!-- Features list -->
        <Border Grid.Row="2" Padding="28,0,28,24">
            <StackPanel Spacing="8">
                <TextBlock Text="INCLUDED IN LICENSE"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#505050" CharacterSpacing="80"/>
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                  FontSize="11" Foreground="#22C55E"/>
                        <TextBlock Text="Online Fix — apply game fixes instantly"
                                   FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                  FontSize="11" Foreground="#22C55E"/>
                        <TextBlock Text="Library management — add games via Lua scripts"
                                   FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                  FontSize="11" Foreground="#22C55E"/>
                        <TextBlock Text="Windows Defender auto-exclusion"
                                   FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE734;" FontFamily="Segoe Fluent Icons"
                                  FontSize="11" Foreground="#8B7CF8"/>
                        <TextBlock Text="Premium fixes — requires Pro license"
                                   FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</ContentDialog>
