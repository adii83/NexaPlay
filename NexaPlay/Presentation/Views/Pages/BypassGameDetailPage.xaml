<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.BypassGameDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    mc:Ignorable="d"
    Background="{ThemeResource NexaSurfaceBrush}">

    <Grid x:Name="RootLayout" SizeChanged="RootLayout_SizeChanged">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1360" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeroTitleText.FontSize" Value="20" />
                        <Setter Target="HeroDescriptionText.FontSize" Value="15" />
                        <Setter Target="HeroDescriptionText.LineHeight" Value="24" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1100" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeroTitleText.FontSize" Value="19" />
                        <Setter Target="HeroDescriptionText.FontSize" Value="14" />
                        <Setter Target="HeroDescriptionText.LineHeight" Value="23" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="CompactState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeroTitleText.FontSize" Value="18" />
                        <Setter Target="HeroDescriptionText.FontSize" Value="13.5" />
                        <Setter Target="HeroDescriptionText.LineHeight" Value="22" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <!-- ═══ Shimmer Skeleton Loading ═══ -->
        <Grid x:Name="ShimmerContainer"
              Visibility="{x:Bind local:BypassGameDetailPage.BoolToVis(ViewModel.IsDetailLoading), Mode=OneWay}"
              Loaded="ShimmerContainer_Loaded"
              Unloaded="ShimmerContainer_Unloaded">
            <Grid.RowDefinitions>
                <RowDefinition Height="520" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.Clip>
                <RectangleGeometry x:Name="ShimmerClipGeometry" Rect="0,0,2000,700" />
            </Grid.Clip>

            <!-- Hero skeleton placeholder -->
            <Border Grid.Row="0" Background="#10FFFFFF" />

            <!-- Bottom metadata skeleton placeholders -->
            <Grid Grid.Row="1" Margin="56,24,56,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Description placeholder lines -->
                <StackPanel Grid.Row="0" Spacing="10" MaxWidth="550" HorizontalAlignment="Left">
                    <Border Background="#10FFFFFF" Height="14" CornerRadius="4" />
                    <Border Background="#10FFFFFF" Height="14" Width="420" HorizontalAlignment="Left" CornerRadius="4" />
                    <Border Background="#10FFFFFF" Height="14" Width="300" HorizontalAlignment="Left" CornerRadius="4" />
                </StackPanel>

                <!-- Genre tags placeholder -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,18,0,0">
                    <Border Background="#10FFFFFF" Height="26" Width="70" CornerRadius="13" />
                    <Border Background="#10FFFFFF" Height="26" Width="90" CornerRadius="13" />
                    <Border Background="#10FFFFFF" Height="26" Width="60" CornerRadius="13" />
                </StackPanel>

                <!-- Badge + metadata row placeholder -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="28" Margin="0,24,0,0">
                    <Border Background="#10FFFFFF" Height="30" Width="90" CornerRadius="5" />
                    <Border Background="#10FFFFFF" Height="30" Width="80" CornerRadius="5" />
                    <StackPanel Spacing="6">
                        <Border Background="#0AFFFFFF" Height="10" Width="50" CornerRadius="3" />
                        <Border Background="#10FFFFFF" Height="16" Width="70" CornerRadius="3" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Background="#0AFFFFFF" Height="10" Width="80" CornerRadius="3" />
                        <Border Background="#10FFFFFF" Height="16" Width="100" CornerRadius="3" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Background="#0AFFFFFF" Height="10" Width="70" CornerRadius="3" />
                        <Border Background="#10FFFFFF" Height="16" Width="110" CornerRadius="3" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Background="#0AFFFFFF" Height="10" Width="65" CornerRadius="3" />
                        <Border Background="#10FFFFFF" Height="16" Width="60" CornerRadius="3" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Background="#0AFFFFFF" Height="10" Width="40" CornerRadius="3" />
                        <Border Background="#10FFFFFF" Height="16" Width="80" CornerRadius="3" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Shimmer sweep overlay -->
            <Border x:Name="ShimmerSweep" Grid.RowSpan="2" IsHitTestVisible="False" Width="600">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ShimmerTranslate" X="-600" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0.0" />
                        <GradientStop Color="#08FFFFFF" Offset="0.25" />
                        <GradientStop Color="#18FFFFFF" Offset="0.5" />
                        <GradientStop Color="#08FFFFFF" Offset="0.75" />
                        <GradientStop Color="Transparent" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <ScrollViewer
            Visibility="{x:Bind local:BypassGameDetailPage.InverseBoolToVis(ViewModel.IsDetailLoading), Mode=OneWay}"
            VerticalScrollBarVisibility="Auto">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeroRowDefinition" Height="520" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Image
                        x:Name="HeroImage"
                        Stretch="UniformToFill"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0"
                        ImageOpened="HeroImage_ImageOpened"
                        ImageFailed="HeroImage_ImageFailed">
                        <Image.Source>
                            <BitmapImage
                                UriSource="{x:Bind local:BypassGameDetailPage.SafeUri(ViewModel.HeroBackgroundUrl), Mode=OneWay}"
                                DecodePixelWidth="3840"
                                DecodePixelHeight="1240" />
                        </Image.Source>
                    </Image>

                    <Grid x:Name="HeroSkeletonOverlay" IsHitTestVisible="False" Background="#22000000">
                        <Border Background="#22FFFFFF" />
                        <Border x:Name="HeroShimmerSweep" Width="560" HorizontalAlignment="Left">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="HeroShimmerTranslate" X="-560" />
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="Transparent" Offset="0.0" />
                                    <GradientStop Color="#16FFFFFF" Offset="0.25" />
                                    <GradientStop Color="#38FFFFFF" Offset="0.5" />
                                    <GradientStop Color="#16FFFFFF" Offset="0.75" />
                                    <GradientStop Color="Transparent" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#C8000000" Offset="0" />
                                <GradientStop Color="#9E000000" Offset="0.5" />
                                <GradientStop Color="#4A000000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border VerticalAlignment="Bottom" Height="220">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#FF080808" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="56,24,56,52">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="2" Spacing="10" MaxWidth="650" HorizontalAlignment="Left">
                            <TextBlock x:Name="HeroDescriptionText"
                                Text="{x:Bind ViewModel.DisplayShortDescription, Mode=OneWay}"
                                Foreground="#D8FFFFFF"
                                FontStyle="Italic"
                                FontSize="14"
                                TextWrapping="WrapWholeWords"
                                LineHeight="24"
                                MaxLines="4" />

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.GenreTags, Mode=OneWay}" HorizontalAlignment="Left">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border
                                            Background="#18000000"
                                            BorderBrush="#60FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,4">
                                            <TextBlock
                                                Text="{x:Bind}"
                                                Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid x:Name="DetailLayoutGrid" Grid.Row="1" Margin="56,16,56,116" ColumnSpacing="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Column="0"
                        Grid.Row="0"
                        Margin="0,0,0,22"
                        ColumnSpacing="28"
                        RowSpacing="12"
                        HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,0,2,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom">
                            <Grid>
                                <Border
                                    Visibility="{x:Bind local:BypassGameDetailPage.BoolToVis(ViewModel.IsPremiumGame), Mode=OneWay}"
                                    Background="{ThemeResource NexaTextPrimaryBrush}"
                                    CornerRadius="5"
                                    Padding="12,6">
                                    <TextBlock
                                        Text="PREMIUM"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="#000000" />
                                </Border>

                                <Border
                                    Visibility="{x:Bind local:BypassGameDetailPage.InverseBoolToVis(ViewModel.IsPremiumGame), Mode=OneWay}"
                                    Background="#16000000"
                                    BorderBrush="#70FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12,6">
                                    <TextBlock
                                        Text="STANDARD"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                </Border>
                            </Grid>

                            <Border
                                Visibility="{x:Bind local:BypassGameDetailPage.BoolToVis(ViewModel.ShowAktivasiOfflineBadge), Mode=OneWay}"
                                Background="#0F766E"
                                BorderBrush="#5EEAD4"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="AKTIVASI OFFLINE"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="#FFFFFF" />
                                </StackPanel>
                            </Border>

                            <Border
                                Visibility="{x:Bind local:BypassGameDetailPage.BoolToVis(ViewModel.ShowSteamSharingBadge), Mode=OneWay}"
                                Background="#0F766E"
                                BorderBrush="#5EEAD4"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="AKUN STEAM"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="#FFFFFF" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="5">
                            <TextBlock Text="APP ID" Foreground="{ThemeResource NexaTextMutedBrush}" CharacterSpacing="80" FontSize="10" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.Game.AppId, Mode=OneWay}" Foreground="{ThemeResource NexaTextPrimaryBrush}" FontSize="14.5" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="5">
                            <TextBlock Text="RELEASE DATE" Foreground="{ThemeResource NexaTextMutedBrush}" CharacterSpacing="80" FontSize="10" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.DisplayReleaseDate, Mode=OneWay}" Foreground="{ThemeResource NexaTextPrimaryBrush}" FontSize="14.5" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="5" MaxWidth="260">
                            <TextBlock Text="DEVELOPER" Foreground="{ThemeResource NexaTextMutedBrush}" CharacterSpacing="80" FontSize="10" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.DisplayDeveloper, Mode=OneWay}" Foreground="{ThemeResource NexaTextPrimaryBrush}" FontSize="14.5" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Spacing="5" MaxWidth="260">
                            <TextBlock Text="PUBLISHER" Foreground="{ThemeResource NexaTextMutedBrush}" CharacterSpacing="80" FontSize="10" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.DisplayPublisher, Mode=OneWay}" Foreground="{ThemeResource NexaTextPrimaryBrush}" FontSize="14.5" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="5" Spacing="5">
                            <TextBlock Text="PRICE" Foreground="{ThemeResource NexaTextMutedBrush}" CharacterSpacing="80" FontSize="10" FontWeight="SemiBold" />
                            <TextBlock
                                Text="{x:Bind ViewModel.DisplayPrice, Mode=OneWay}"
                                Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                FontSize="14.5"
                                FontWeight="SemiBold"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>

                    <!-- Thin divider between metadata strip and content section -->
                    <Border
                        Grid.Column="0"
                        Grid.Row="1"
                        Height="1"
                        Margin="0,0,0,0"
                        Background="#18FFFFFF" />

                    <!-- 3rd Party Games Section -->
                    <StackPanel
                        Grid.Column="0"
                        Grid.Row="2"
                        Visibility="{x:Bind local:BypassGameDetailPage.BoolToVis(ViewModel.ShowThirdPartySection), Mode=OneWay}"
                        Spacing="0">

                        <!-- Title: separate from 2-col grid so it always renders above cards -->
                        <TextBlock
                            Text="Mohon Dibaca Sebentar!!"
                            Foreground="{ThemeResource NexaTextPrimaryBrush}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            CharacterSpacing="-10"
                            Margin="0,24,0,16" />

                        <!-- 2-column: left=cards+button, right=cover art -->
                        <Grid ColumnSpacing="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="258" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Info cards + button -->
                            <StackPanel
                                Grid.Column="0"
                                Spacing="12">

                                <!-- Card 1: Antivirus (⚠️ Warning) -->
                                <Border
                                    Background="#141414"
                                    BorderBrush="#2E2E2E"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="18,14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- ⚠️ icon replaced with FontIcon -->
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="&#xE7BA;"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="18"
                                            Foreground="#FFFFFF"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock
                                                Text="Antivirus"
                                                Foreground="#FFFFFF"
                                                FontSize="14.5"
                                                FontWeight="SemiBold" />
                                            <TextBlock
                                                Foreground="#C8C8C8"
                                                FontSize="13"
                                                LineHeight="21"
                                                TextWrapping="WrapWholeWords">
                                                <Run Text="Untuk hasil terbaik, gunakan " />
                                                <Run Text="Windows Defender" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" saja. Jika Anda menggunakan antivirus lain, sebaiknya " />
                                                <Run Text="uninstall" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" terlebih dahulu dan aktifkan Windows Defender agar " />
                                                <Run Text="Proses Bypass Game" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" berjalan dengan sempurna." />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Card 2: Windows Update (📖 Book) -->
                                <Border
                                    Background="#141414"
                                    BorderBrush="#2E2E2E"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="18,14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 📖 icon replaced with FontIcon -->
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="&#xE82D;"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="18"
                                            Foreground="#FFFFFF"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock
                                                Text="Windows Update"
                                                Foreground="#FFFFFF"
                                                FontSize="14.5"
                                                FontWeight="SemiBold" />
                                            <TextBlock
                                                Foreground="#C8C8C8"
                                                FontSize="13"
                                                LineHeight="21"
                                                TextWrapping="WrapWholeWords">
                                                <Run Text="Setelah Windows Update, game harus melalui " />
                                                <Run Text="&quot;Proses Bypass Game&quot;" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text="ulang. Jika ingin bebas dari " />
                                                <Run Text="&quot;Proses Bypass Game Selamanya&quot;" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=", disarankan nonaktifkan Windows Update - juga bisa menghemat ruang penyimpanan." />
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <FontIcon
                                                    Glyph="&#xE896;"
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="14"
                                                    Foreground="#C8C8C8"
                                                    VerticalAlignment="Center" />
                                                <TextBlock
                                                    Text="Download Tool:"
                                                    Foreground="#C8C8C8"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    VerticalAlignment="Center" />
                                                <HyperlinkButton
                                                    NavigateUri="https://drive.google.com/uc?export=download&amp;id=1aWMeHqFrLQvbTFQO2YrVedGny6PQ2HAE"
                                                    Padding="0"
                                                    Margin="0,-4,0,-4">
                                                    <TextBlock
                                                        Text="Windows Disable Update"
                                                        Foreground="#4DA6FF"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        TextDecorations="Underline" />
                                                </HyperlinkButton>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Card 3: Laporkan Masalah (🐛 Bug) -->
                                <Border
                                    Background="#141414"
                                    BorderBrush="#2E2E2E"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="18,14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 🐛 icon replaced with FontIcon -->
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="&#xEBE8;"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="18"
                                            Foreground="#FFFFFF"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock
                                                Text="Laporkan Masalah"
                                                Foreground="#FFFFFF"
                                                FontSize="14.5"
                                                FontWeight="SemiBold" />
                                            <TextBlock
                                                Foreground="#C8C8C8"
                                                FontSize="13"
                                                LineHeight="21"
                                                TextWrapping="WrapWholeWords">
                                                <Run Text="Jika Anda menemukan " />
                                                <Run Text="error" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" atau " />
                                                <Run Text="bug" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" selama proses fix, harap segera " />
                                                <Run Text="laporkan" FontWeight="Bold" Foreground="#FFFFFF" />
                                                <Run Text=" kepada admin agar dapat ditangani dengan cepat." />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Mulai Bypass Button — white bg + glow border on hover -->
                                <Grid
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0"
                                    PointerEntered="BypassBtn_PointerEntered"
                                    PointerExited="BypassBtn_PointerExited">
                                    <!-- Glow ring behind the button (animated on hover) -->
                                    <Border
                                        x:Name="BypassBtnGlow"
                                        CornerRadius="10"
                                        BorderThickness="2"
                                        BorderBrush="#80FFFFFF"
                                        Opacity="0"
                                        Margin="-3"
                                        IsHitTestVisible="False" />
                                    <Button
                                        Click="StartBypassBtn_Click"
                                        MinWidth="200"
                                        Height="44"
                                        Padding="22,0"
                                        Background="#FFFFFF"
                                        Foreground="#000000"
                                        BorderBrush="#FFFFFF"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Content="Mulai Bypass Game">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFFFFF" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E8E8E8" />
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#000000" />
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#000000" />
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFFFFF" />
                                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#CCCCCC" />
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- RIGHT: Game Cover Art (library capsule portrait) -->
                            <Border
                                Grid.Column="1"
                                VerticalAlignment="Top"
                                CornerRadius="12"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1"
                                Background="#101010"
                                Width="258"
                                Height="387"
                                PointerEntered="CoverArtCard_PointerEntered"
                                PointerExited="CoverArtCard_PointerExited">
                                <Grid CornerRadius="11">
                                    <Border x:Name="CoverArtSkeleton" Background="#18FFFFFF" CornerRadius="11" />
                                    <Image x:Name="CoverArtImage"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0"
                                           ImageOpened="CoverArtImage_ImageOpened"
                                           ImageFailed="CoverArtImage_ImageFailed">
                                        <Image.Source>
                                            <BitmapImage
                                                UriSource="{x:Bind local:BypassGameDetailPage.SafeUri(ViewModel.CoverArtUrl), Mode=OneWay}"
                                                DecodePixelWidth="516"
                                                DecodePixelHeight="774" />
                                        </Image.Source>
                                    </Image>
                                    <Border VerticalAlignment="Bottom" Height="80" CornerRadius="0,0,11,11">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#80000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border
                                        x:Name="CoverArtHoverOverlay"
                                        CornerRadius="11"
                                        BorderThickness="2"
                                        BorderBrush="#CCFFFFFF"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Default (No Aktivasi Offline) Section removed duplicate -->
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Top Bar Overlay -->
        <Border
            x:Name="TopBarOverlay"
            VerticalAlignment="Top"
            Height="66"
            BorderThickness="0"
            Padding="14,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#B8141414" Offset="0" />
                    <GradientStop Color="#86141414" Offset="0.46" />
                    <GradientStop Color="#18141414" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Width="34"
                    Height="34"
                    Click="BackButton_Click"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#24000000"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="17"
                    Padding="0">
                    <FontIcon
                        Glyph="&#xE72B;"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                </Button>

                <Border
                    Grid.Column="1"
                    Width="30"
                    Height="30"
                    Margin="2,0,0,0"
                    VerticalAlignment="Center"
                    CornerRadius="3"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    Background="#22000000">
                    <Grid>
                        <Image Stretch="UniformToFill"
                               Opacity="0"
                               Loaded="TopIconImage_Loaded"
                               ImageOpened="TopIconImage_ImageOpened"
                               ImageFailed="TopIconImage_ImageFailed">
                            <Image.Source>
                                <BitmapImage
                                    UriSource="{x:Bind local:BypassGameDetailPage.SafeUri(ViewModel.GameIconUrl), Mode=OneWay}"
                                    DecodePixelWidth="80" />
                            </Image.Source>
                        </Image>
                        <Grid x:Name="TopIconSkeletonOverlay" IsHitTestVisible="False" Background="#22FFFFFF">
                            <Border x:Name="TopIconShimmerSweep" Width="26" HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="TopIconShimmerTranslate" X="-26" />
                                </Border.RenderTransform>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#14FFFFFF" Offset="0.24" />
                                        <GradientStop Color="#34FFFFFF" Offset="0.50" />
                                        <GradientStop Color="#14FFFFFF" Offset="0.76" />
                                        <GradientStop Color="Transparent" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock x:Name="HeroTitleText"
                    Grid.Column="2"
                    Margin="2,0,0,0"
                    Text="{x:Bind ViewModel.Game.Name, Mode=OneWay}"
                    Foreground="{ThemeResource NexaTextPrimaryBrush}"
                    FontWeight="SemiBold"
                    FontSize="19"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <ContentDialog x:Name="OfflineActivationDialog"
                       Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                       BorderBrush="{ThemeResource NexaBorderBrush}"
                       CornerRadius="12"
                       PrimaryButtonText="Lanjut Bypass"
                       CloseButtonText="Kembali"
                       DefaultButton="Primary"
                       PrimaryButtonClick="OfflineActivationDialog_PrimaryButtonClick">
            <ContentDialog.Resources>
                <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#FFFFFF" />
                <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#E5E5E5" />
                <SolidColorBrush x:Key="SystemControlForegroundChromeWhiteBrush" Color="#000000" />
                <!-- Fallback for newer WinUI versions -->
                <SolidColorBrush x:Key="AccentButtonBackground" Color="#FFFFFF" />
                <SolidColorBrush x:Key="AccentButtonForeground" Color="#000000" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#E5E5E5" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#CCCCCC" />
                <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#000000" />
                <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#000000" />
            </ContentDialog.Resources>

            <ContentDialog.Title>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                    <FontIcon Glyph="&#xE7BA;" FontFamily="Segoe Fluent Icons" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <TextBlock Text="AKTIVASI OFFLINE" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <FontIcon Glyph="&#xE7BA;" FontFamily="Segoe Fluent Icons" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                </StackPanel>
            </ContentDialog.Title>
            
            <StackPanel Spacing="16" MaxWidth="450">
                <TextBlock Text="!! Mohon dibaca sebelum melanjutkan!" FontWeight="Bold" FontSize="16" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="-" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextWrapping="WrapWholeWords" LineHeight="22">
                            <Run Text="Game ini memerlukan aktivasi offline dan mengharuskan Anda untuk menonaktifkan Windows Update terlebih dahulu." />
                            <LineBreak />
                            <Run Text="Silakan download dan gunakan tools " />
                            <Run Text="Windows Disable Update." FontWeight="Bold" />
                        </TextBlock>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="-" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextWrapping="WrapWholeWords" LineHeight="22">
                            <Run Text="Setelah Windows Update berhasil dinonaktifkan, lanjutkan Proses Bypass Game seperti biasa." />
                        </TextBlock>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="-" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextWrapping="WrapWholeWords" LineHeight="22">
                            <Run Text="Setelah proses fix selesai, segera hubungi Admin melalui WhatsApp untuk melanjutkan proses aktivasi offline." />
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <CheckBox x:Name="OfflineActivationCheckbox"
                          Content="Saya telah membaca, memahami, dan menggunakan fitur Windows Disable Update sesuai petunjuk"
                          Foreground="{ThemeResource NexaTextPrimaryBrush}"
                          Margin="0,10,0,0"
                          Checked="OfflineActivationCheckbox_Changed"
                          Unchecked="OfflineActivationCheckbox_Changed">
                    <CheckBox.Resources>
                        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#FFFFFF" />
                        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#E5E5E5" />
                        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#CCCCCC" />
                        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#000000" />
                        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" Color="#000000" />
                        <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" Color="#000000" />
                    </CheckBox.Resources>
                </CheckBox>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
