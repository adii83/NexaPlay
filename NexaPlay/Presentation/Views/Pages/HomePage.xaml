<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NexaPlay.Core.Models"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    NavigationCacheMode="Required"
    mc:Ignorable="d"
    Background="#080808">

    <Grid>
        <!-- Loading State -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                      Visibility="{x:Bind local:HomePage.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                      Width="44" Height="44" Foreground="{ThemeResource NexaAccentBrush}" />
        
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      Visibility="{x:Bind local:HomePage.InverseBoolToVis(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel Padding="28,20,28,60" Spacing="40">
                
                <!-- HEADER TITLE DIHAPUS SESUAI PERMINTAAN -->

                <!-- SECTION 1: NEW BYPASS GAMES (Horizontal Scroll) -->
                <StackPanel Spacing="16">
                    <Grid x:Name="PopularGamesHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Width="6" Height="24" CornerRadius="3" Background="{ThemeResource NexaTextPrimaryBrush}" />
                            <TextBlock Text="New Bypass Games" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Click="OnBrowseBypassClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right">
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <TextBlock Text="Lihat Bypass"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                    <FontIcon Glyph="&#xE72A;"
                                              FontSize="12"
                                              Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                </StackPanel>
                                <Border Height="1"
                                        Width="108"
                                        HorizontalAlignment="Right"
                                        Background="#80FFFFFF" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid x:Name="NewBypassHeroContainer"
                          Height="560"
                          CornerRadius="12"
                          Background="{ThemeResource NexaCardBrush}"
                          BorderBrush="{ThemeResource NexaCardBorderBrush}"
                          BorderThickness="1">
                        <FlipView x:Name="HeroCarousel" ItemsSource="{x:Bind ViewModel.RecentFixes, Mode=OneWay}" SelectionChanged="HeroCarousel_SelectionChanged" UseTouchAnimationsForAllNavigation="True">
                            <FlipView.Resources>
                                <!-- Hack pamungkas: Panah bawaan FlipView adalah komponen Button. Kita sembunyikan semua Button di level ini! -->
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </FlipView.Resources>
                            <FlipView.ItemTemplate>
                                <DataTemplate x:DataType="models:FixEntry">
                                    <Grid>
                                        <!-- Background Image -->
                                        <Border CornerRadius="12">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind local:HomePage.SafeImageSource(PosterUrl), Mode=OneTime}"
                                                            Stretch="UniformToFill"
                                                            AlignmentX="Center"
                                                            AlignmentY="Center" />
                                            </Border.Background>
                                        </Border>
                                        
                                        <!-- Gradient Overlay for readability -->
                                        <Border CornerRadius="12">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#00000000" Offset="0.1" />
                                                    <GradientStop Color="#E6000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        
                                        <!-- Premium / Standard Label (Top-Left) -->
                                        <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24">
                                            <!-- PREMIUM Badge -->
                                            <Border Visibility="{x:Bind local:HomePage.BoolToVis(IsPremium)}" 
                                                    Background="{ThemeResource NexaTextPrimaryBrush}" 
                                                    CornerRadius="4" Padding="12,6">
                                                <TextBlock Text="PREMIUM" FontSize="12" FontWeight="Bold" Foreground="#000000" />
                                            </Border>
                                            
                                            <!-- STANDARD Badge -->
                                            <Border Visibility="{x:Bind local:HomePage.InverseBoolToVis(IsPremium)}" 
                                                    Background="#000000" 
                                                    BorderBrush="#4DFFFFFF" BorderThickness="1"
                                                    CornerRadius="4" Padding="12,6">
                                                <TextBlock Text="STANDARD" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                            </Border>
                                        </Grid>
                                        
                                        <!-- Content Info (Bottom-Left) -->
                                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32" Spacing="16" MaxWidth="700">
                                            <StackPanel Spacing="4">
                                                <!-- Title -->
                                                <TextBlock Text="{x:Bind Title}" FontSize="36" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                
                                                <!-- Description (Placeholder karena model belum memiliki field Description) -->
                                                <TextBlock Text="Rasakan pengalaman bermain game yang tak terlupakan dengan performa maksimal. Jelajahi dunia baru, selesaikan misi menantang, dan taklukkan setiap rintangan dengan NexaPlay Bypass." 
                                                           FontStyle="Italic" FontSize="14" Foreground="#CCCCCC" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            
                                            <!-- Genres Pill -->
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border BorderBrush="{ThemeResource NexaTextPrimaryBrush}" BorderThickness="1" CornerRadius="16" Padding="16,6">
                                                    <TextBlock Text="{x:Bind Category}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" CharacterSpacing="50" />
                                                </Border>
                                                <Border BorderBrush="{ThemeResource NexaTextPrimaryBrush}" BorderThickness="1" CornerRadius="16" Padding="16,6">
                                                    <TextBlock Text="SINGLEPLAYER" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" CharacterSpacing="50" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Action CTA custom agar hover text bisa dikontrol penuh tanpa visual-state bawaan HyperlinkButton -->
                                        <Border Tag="{x:Bind}"
                                                Tapped="OnHeroBypassTapped"
                                                PointerEntered="HeroBypassButton_PointerEntered"
                                                PointerExited="HeroBypassButton_PointerExited"
                                                VerticalAlignment="Bottom"
                                                HorizontalAlignment="Right"
                                                Margin="32"
                                                Height="44"
                                                Padding="32,0"
                                                Background="{ThemeResource NexaTextPrimaryBrush}"
                                                CornerRadius="8">
                                            <TextBlock x:Name="HeroBypassButtonText"
                                                       Text="View Bypass"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#000000"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>

                        <!-- Custom Pips (Bulatan Melebar) di Tengah Bawah -->
                        <StackPanel x:Name="CustomPipsContainer" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24" Spacing="6" />
                    </Grid>
                </StackPanel>

                <!-- SECTION 2: POPULAR GAMES (Grid Layout) -->
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Width="6" Height="24" CornerRadius="3" Background="{ThemeResource NexaTextPrimaryBrush}" />
                            <TextBlock Text="Popular Games" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Click="OnBrowseGamesClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right">
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <TextBlock Text="Jelajahi Games"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                    <FontIcon Glyph="&#xE72A;"
                                              FontSize="12"
                                              Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                </StackPanel>
                                <Border Height="1"
                                        Width="116"
                                        HorizontalAlignment="Right"
                                        Background="#80FFFFFF" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <GridView x:Name="PopularGamesGrid"
                              SizeChanged="PopularGamesGrid_SizeChanged"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.PopularGames, Mode=OneWay}"
                              IsItemClickEnabled="False"
                              SelectionMode="None"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemContainerTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition IsStaggeringEnabled="True" />
                            </TransitionCollection>
                        </GridView.ItemContainerTransitions>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               ItemWidth="220"
                                               ItemHeight="330"
                                               MaximumRowsOrColumns="5" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:GameEntry">
                                <!--
                                    PopularGameCardStyle membungkus seluruh card.
                                    Hover: scale 1.03 + border putih lebih terang (HoverBorderOverlay).
                                    Pressed: scale 0.98 + flash putih tipis.
                                    Konten card tetap sama persis — hanya container yang berubah.
                                -->
                                <Button Style="{StaticResource PopularGameCardStyle}"
                                        Click="OnPopularGameCardClicked"
                                        PointerEntered="PopularGameCard_PointerEntered"
                                        PointerExited="PopularGameCard_PointerExited"
                                        Tag="{x:Bind AppId}"
                                        HorizontalAlignment="Stretch">
                                    <Grid CornerRadius="12"
                                          BorderBrush="{ThemeResource NexaCardBorderBrush}"
                                          BorderThickness="1">

                                        <!-- Header Image Area -->
                                        <Border CornerRadius="12">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind local:HomePage.SafeImageSource(PopularCoverImageUrl), Mode=OneTime}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>

                                        <Border CornerRadius="12"
                                                Background="#101418"
                                                Visibility="{x:Bind local:HomePage.InverseBoolToVis(HasPopularCover), Mode=OneTime}">
                                            <TextBlock Text="NO CONTENT"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#CCFFFFFF"
                                                       CharacterSpacing="120" />
                                        </Border>

                                        <!-- Gradient Overlay for readability -->
                                        <Border CornerRadius="12">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#00000000" Offset="0.2" />
                                                    <GradientStop Color="#E6000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- Badges (Top-Left) -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Spacing="8">
                                            <Grid>
                                                <!-- PREMIUM Badge -->
                                                <Border Visibility="{x:Bind local:HomePage.BoolToVis(IsPremium)}"
                                                        Background="{ThemeResource NexaTextPrimaryBrush}"
                                                        CornerRadius="4" Padding="8,4">
                                                    <TextBlock Text="PREMIUM" FontSize="10" FontWeight="Bold" Foreground="#000000" />
                                                </Border>
                                                <!-- STANDARD Badge -->
                                                <Border Visibility="{x:Bind local:HomePage.InverseBoolToVis(IsPremium)}"
                                                        Background="#000000"
                                                        BorderBrush="#4DFFFFFF" BorderThickness="1"
                                                        CornerRadius="4" Padding="8,4">
                                                    <TextBlock Text="STANDARD" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                                </Border>
                                            </Grid>
                                        </StackPanel>

                                        <!-- DENUVO Badge (Top-Right) -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                                Visibility="{x:Bind local:HomePage.BoolToVis(HasDenuvo)}"
                                                Background="#EAB308"
                                                BorderBrush="#FEF08A" BorderThickness="1.5"
                                                CornerRadius="4" Padding="6,4"
                                                Loaded="DenuvoBadge_Loaded">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" FontSize="10" Foreground="#FFFFFF" FontWeight="Bold" />
                                                <TextBlock Text="DENUVO" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Hover Title Layer (default hidden, slide-up on hover) -->
                                        <Border x:Name="HoverTitleLayer"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,1"
                                                Padding="12,30,12,14"
                                                Opacity="0"
                                                IsHitTestVisible="False">
                                            <Border.RenderTransform>
                                                <TranslateTransform Y="14" />
                                            </Border.RenderTransform>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#00000000" Offset="0.0" />
                                                    <GradientStop Color="#99000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{x:Bind Name}"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <Button Content="Tampilkan Lebih Banyak" Command="{x:Bind ViewModel.LoadMorePopularGamesCommand}" HorizontalAlignment="Center" Margin="0,16,0,0" Height="40" Padding="24,0" Background="Transparent" BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1" CornerRadius="8" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
