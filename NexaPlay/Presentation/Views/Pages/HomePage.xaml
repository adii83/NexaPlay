<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NexaPlay.Core.Models"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <!-- Loading State -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                      Visibility="{x:Bind local:HomePage.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                      Width="44" Height="44" Foreground="{ThemeResource NexaAccentBrush}" />
        
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      Visibility="{x:Bind local:HomePage.InverseBoolToVis(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel Padding="28,16,28,40" Spacing="32">
                
                <!-- HERO BANNER -->
                <Grid CornerRadius="16" Height="300"
                      Background="#1A1A1A"
                      BorderBrush="{ThemeResource NexaBorderBrush}"
                      BorderThickness="1">
                    <!-- Placeholder Background for Hero -->
                    <Grid>
                        <!-- Fallback solid color -->
                        <Border Background="#151515" CornerRadius="16" />
                        <!-- Subtle gradient -->
                        <Border CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B7CF833" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                    
                    <Grid Padding="32,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Info -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Spacing="12">
                            <Border Background="#8B7CF8" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="FEATURED UPDATE" FontSize="10" FontWeight="Bold" Foreground="White" CharacterSpacing="60"/>
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.HeroGame.Title, Mode=OneWay, FallbackValue='Game Title'}" 
                                       FontSize="36" FontWeight="Bold" 
                                       Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.HeroGame.Publisher, Mode=OneWay, FallbackValue='Publisher'}" 
                                       FontSize="14" Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                            <Button Margin="0,12,0,0" 
                                    Height="40" Padding="20,0" 
                                    CornerRadius="8"
                                    Background="{ThemeResource NexaAccentBrush}" 
                                    Foreground="White"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    <TextBlock Text="View Details" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- POPULAR GAMES CAROUSEL -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Popular Fixes" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.PopularGames, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="16"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:FixEntry">
                                    <!-- Card -->
                                    <Grid Width="160" Height="220" CornerRadius="12" Background="{ThemeResource NexaSurfaceBrush}" BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Poster (Placeholder) -->
                                            <Border Height="140" Background="#222222" CornerRadius="12,12,0,0">
                                                <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="#444444" />
                                            </Border>
                                            <StackPanel Padding="12" Spacing="4">
                                                <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind Publisher}" FontSize="11" Foreground="{ThemeResource NexaTextMutedBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- NEW FIXES GRID -->
                <StackPanel Spacing="16">
                    <TextBlock Text="New Arrivals" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentFixes, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="200" MinRowSpacing="16" MinColumnSpacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:FixEntry">
                                <!-- Card -->
                                <Grid Height="280" CornerRadius="12" Background="{ThemeResource NexaSurfaceBrush}" BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Poster (Placeholder) -->
                                        <Border Height="180" Background="#222222" CornerRadius="12,12,0,0">
                                            <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="32" Foreground="#444444" />
                                        </Border>
                                        <StackPanel Padding="16" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Category.ToString()}" FontSize="12" Foreground="{ThemeResource NexaTextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Premium Badge -->
                                    <Border Visibility="{x:Bind local:HomePage.BoolToVis(IsPremium)}" 
                                            Background="#F59E0B" CornerRadius="6" Padding="6,2" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top" 
                                            Margin="8,8,8,0">
                                        <TextBlock Text="PRO" FontSize="9" FontWeight="Bold" Foreground="White" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
