<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NexaPlay.Core.Models"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <!-- Loading State -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                      Visibility="{x:Bind local:HomePage.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                      Width="44" Height="44" Foreground="{ThemeResource NexaAccentBrush}" />
        
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      Visibility="{x:Bind local:HomePage.InverseBoolToVis(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel Padding="28,16,28,40" Spacing="32">
                
                <!-- HERO BANNER -->
                <Grid CornerRadius="8" Height="280"
                      Background="{ThemeResource NexaSurfaceElevatedBrush}"
                      BorderBrush="{ThemeResource NexaBorderBrush}"
                      BorderThickness="1">
                    <!-- Placeholder Background for Hero -->
                    <Grid>
                        <Border Background="{ThemeResource NexaSurfaceBrush}" CornerRadius="8" />
                    </Grid>
                    
                    <Grid Padding="32,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Info -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Spacing="12">
                            <Border BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="FEATURED" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource NexaTextSecondaryBrush}" CharacterSpacing="50"/>
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.HeroGame.Title, Mode=OneWay, FallbackValue='Game Title'}" 
                                       FontSize="36" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.HeroGame.Publisher, Mode=OneWay, FallbackValue='Publisher'}" 
                                       FontSize="14" Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                            <Button Margin="0,12,0,0" 
                                    Height="36" Padding="24,0" 
                                    CornerRadius="4"
                                    Background="{ThemeResource NexaTextPrimaryBrush}" 
                                    Foreground="{ThemeResource NexaSurfaceBrush}"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="View Details" FontWeight="Medium" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- POPULAR GAMES CAROUSEL -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Popular Games" FontSize="16" FontWeight="Medium" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.PopularGames, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="16"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:FixEntry">
                                    <!-- Card -->
                                    <Grid Width="160" Height="220" CornerRadius="6" Background="{ThemeResource NexaSurfaceBrush}" BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Poster (Placeholder) -->
                                            <Border Height="140" Background="{ThemeResource NexaSurfaceElevatedBrush}" CornerRadius="6,6,0,0">
                                                <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{ThemeResource NexaTextMutedBrush}" />
                                            </Border>
                                            <StackPanel Padding="12" Spacing="4">
                                                <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="Medium" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind Publisher}" FontSize="11" Foreground="{ThemeResource NexaTextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- NEW FIXES GRID -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Latest Releases" FontSize="16" FontWeight="Medium" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentFixes, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="200" MinRowSpacing="16" MinColumnSpacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:FixEntry">
                                <!-- Card -->
                                <Grid Height="280" CornerRadius="6" Background="{ThemeResource NexaSurfaceBrush}" BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Poster (Placeholder) -->
                                        <Border Height="180" Background="{ThemeResource NexaSurfaceElevatedBrush}" CornerRadius="6,6,0,0">
                                            <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="32" Foreground="{ThemeResource NexaTextMutedBrush}" />
                                        </Border>
                                        <StackPanel Padding="16" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource NexaTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Category.ToString()}" FontSize="12" Foreground="{ThemeResource NexaTextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Premium Badge -->
                                    <Border Visibility="{x:Bind local:HomePage.BoolToVis(IsPremium)}" 
                                            Background="{ThemeResource NexaWarningBrush}" CornerRadius="4" Padding="6,2" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top" 
                                            Margin="8,8,8,0">
                                        <TextBlock Text="PRO" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource NexaSurfaceBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
