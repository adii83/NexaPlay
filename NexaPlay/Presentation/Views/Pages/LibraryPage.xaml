<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="NexaPlay.Presentation.Views.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NexaPlay.Core.Models"
    xmlns:viewModels="using:NexaPlay.Presentation.ViewModels"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    NavigationCacheMode="Required"
    mc:Ignorable="d"
    Background="#080808">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header (tanpa teks Library) -->
        <Border Grid.Row="0"
                Margin="20,16,20,0"
                Padding="16,14,16,14"
                CornerRadius="14"
                BorderBrush="#2CFFFFFF"
                BorderThickness="1"
                Background="#D10A0A0A">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border CornerRadius="8" BorderThickness="1" Loaded="SearchLaser_Loaded">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D0D0D" Offset="0.0" />
                                <GradientStop x:Name="BgGlowLeft" Color="#1A1A1A" Offset="0.5" />
                                <GradientStop x:Name="BgGlowRight" Color="#1A1A1A" Offset="0.5" />
                                <GradientStop Color="#0D0D0D" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#22FFFFFF" Offset="0.0" />
                                <GradientStop x:Name="BorderGlowLeft" Color="#FFFFFFFF" Offset="0.5" />
                                <GradientStop x:Name="BorderGlowRight" Color="#FFFFFFFF" Offset="0.5" />
                                <GradientStop Color="#22FFFFFF" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        
                        <TextBox x:Name="SearchBox"
                                 PlaceholderText="Search Game..."
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CornerRadius="8"
                                 FontSize="14"
                                 Padding="14,8,14,4"
                                 VerticalContentAlignment="Center"
                                 PlaceholderForeground="#B8C6D8"
                                 Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    </Border>
                </Grid>

                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.SearchNowCommand}"
                        Height="42"
                        MinWidth="56"
                        MaxWidth="56"
                        Padding="0">
                    <FontIcon Glyph="&#xE721;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="White"
                              FontSize="15" />
                </Button>

                <Button Grid.Column="2"
                        Command="{x:Bind ViewModel.RestartSteamCommand}"
                        Height="42"
                        Padding="12,0"
                        Background="Transparent"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <SymbolIcon Symbol="Refresh" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                        <TextBlock Text="Restart Steam" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource NexaTextPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ProgressBar Grid.Row="0"
                         IsIndeterminate="True"
                         Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                         VerticalAlignment="Top"
                         Height="2"
                         Margin="20,8,20,0" />

            <!-- Empty State -->
            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.IsEmpty), Mode=OneWay}">
                <FontIcon Glyph="&#xED43;" FontFamily="Segoe Fluent Icons" FontSize="72" Foreground="#40FFFFFF" Margin="0,0,0,8" />
                <TextBlock Text="Library Anda Kosong" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="Belum ada game terdeteksi di perangkat ini." FontSize="15" Foreground="#99FFFFFF" HorizontalAlignment="Center" />
                <Button Content="Jelajahi Games"
                        Command="{x:Bind ViewModel.NavigateToGamesCommand}"
                        Height="40"
                        Padding="24,0"
                        Margin="0,12,0,0"
                        Background="#FFFFFF"
                        Foreground="#000000"
                        FontWeight="Bold"
                        CornerRadius="8"
                        HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Library ListView -->
            <ListView x:Name="LibraryList"
                      Grid.Row="0"
                      Margin="0,14,0,10"
                      Padding="20,0,20,0"
                      ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                      IsItemClickEnabled="True"
                      ItemClick="OnGameItemClicked"
                      SelectionMode="None"
                      Visibility="{x:Bind local:LibraryPage.InverseBoolToVis(ViewModel.IsEmpty), Mode=OneWay}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemContainerTransitions>
                    <TransitionCollection />
                </ListView.ItemContainerTransitions>
                
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:LibraryGameCard">
                        <Border CornerRadius="8"
                                Background="#0F0F0F"
                                BorderBrush="{ThemeResource NexaCardBorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                PointerEntered="ListItem_PointerEntered"
                                PointerExited="ListItem_PointerExited"
                                x:Name="RootCardBorder">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Column 0: Image with badges over it -->
                                <Grid Grid.Column="0" Width="190" Height="85" CornerRadius="6">
                                    <Border Visibility="{x:Bind local:LibraryPage.BoolToVis(HasCover), Mode=OneTime}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{x:Bind local:LibraryPage.ToImageSource(PosterUrl), Mode=OneTime}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <Border Background="#1A1A1A"
                                            Visibility="{x:Bind local:LibraryPage.InverseBoolToVis(HasCover), Mode=OneTime}">
                                        <TextBlock Text="UNKNOWN GAME"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#80FFFFFF" />
                                    </Border>
                                    <!-- Badge over image (Standard/Premium) -->
                                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                                        <Grid>
                                            <Border Visibility="{x:Bind local:LibraryPage.BoolToVis(IsPremium), Mode=OneTime}"
                                                    Background="{ThemeResource NexaTextPrimaryBrush}"
                                                    CornerRadius="4" Padding="8,4">
                                                <TextBlock Text="PREMIUM" FontSize="10" FontWeight="Bold" Foreground="#000000" />
                                            </Border>
                                            <Border Visibility="{x:Bind local:LibraryPage.InverseBoolToVis(IsPremium), Mode=OneTime}"
                                                    Background="#000000"
                                                    BorderBrush="#4DFFFFFF" BorderThickness="1"
                                                    CornerRadius="4" Padding="8,4">
                                                <TextBlock Text="STANDARD" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Column 1: Title and Genre -->
                                <Grid Grid.Column="1" Margin="0,8,0,8">
                                    <TextBlock Text="{x:Bind Title}" FontSize="18" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" Margin="0,4,0,0" />
                                    <TextBlock Text="{x:Bind Genre}" FontSize="14" Foreground="#99FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                                </Grid>
                                
                                <!-- Column 2: AppID, Denuvo Badge, and Trash Button -->
                                <Grid Grid.Column="2" Margin="0,8,10,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Spacing="12">
                                        <Border Visibility="{x:Bind local:LibraryPage.BoolToVis(HasDenuvo), Mode=OneTime}"
                                                Background="#EAB308"
                                                BorderBrush="#FEF08A" BorderThickness="1.5"
                                                CornerRadius="4" Padding="6,4"
                                                Loaded="DenuvoBadge_Loaded">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE7BA;" FontSize="10" Foreground="#FFFFFF" FontWeight="Bold" />
                                                <TextBlock Text="DENUVO" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                        
                                        <Button Click="OnRemoveGameClicked"
                                                Tag="{x:Bind AppId}"
                                                CornerRadius="8"
                                                Width="32" Height="32"
                                                Padding="0"
                                                Background="White"
                                                BorderThickness="0"
                                                ToolTipService.ToolTip="Hapus dari Library">
                                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="Black" />
                                        </Button>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{x:Bind AppIdDisplay}" 
                                               FontSize="13" 
                                               Foreground="#66FFFFFF" 
                                               VerticalAlignment="Bottom" 
                                               HorizontalAlignment="Right" 
                                               Margin="0,0,0,4" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                
                <ListView.Footer>
                    <Border Margin="0,12,0,16"
                            Background="#0A0A0A"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,8"
                            HorizontalAlignment="Center"
                            Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.ShowPager), Mode=OneWay}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Prev"
                                    Command="{x:Bind ViewModel.PreviousPageCommand}"
                                    Background="#121212"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    IsEnabled="{x:Bind ViewModel.CanGoPrevious, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Content="{x:Bind ViewModel.PageSlot1, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot1, Mode=OneWay}"
                                    Background="{x:Bind local:LibraryPage.PageButtonBackground(ViewModel.IsPage1Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:LibraryPage.PageButtonForeground(ViewModel.IsPage1Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.ShowPage1), Mode=OneWay}" />
                            <Button Grid.Column="2"
                                    Content="{x:Bind ViewModel.PageSlot2, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot2, Mode=OneWay}"
                                    Background="{x:Bind local:LibraryPage.PageButtonBackground(ViewModel.IsPage2Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:LibraryPage.PageButtonForeground(ViewModel.IsPage2Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.ShowPage2), Mode=OneWay}" />
                            <Button Grid.Column="3"
                                    Content="{x:Bind ViewModel.PageSlot3, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot3, Mode=OneWay}"
                                    Background="{x:Bind local:LibraryPage.PageButtonBackground(ViewModel.IsPage3Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:LibraryPage.PageButtonForeground(ViewModel.IsPage3Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:LibraryPage.BoolToVis(ViewModel.ShowPage3), Mode=OneWay}" />
                            <Button Grid.Column="4"
                                    Content="Next"
                                    Command="{x:Bind ViewModel.NextPageCommand}"
                                    Background="#121212"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" />
                        </Grid>
                    </Border>
                </ListView.Footer>
            </ListView>
        </Grid>

        <Grid
            x:Name="LibraryRemoveConfirmOverlay"
            Grid.RowSpan="2"
            Visibility="Collapsed"
            Background="#B3000000"
            IsHitTestVisible="True">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="680"
                MaxWidth="980"
                Margin="18"
                CornerRadius="16"
                Background="#0A0A0A"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                Padding="28">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Remove Game"
                        Foreground="{ThemeResource NexaTextPrimaryBrush}"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="LibraryRemoveConfirmMessageText"
                        Foreground="{ThemeResource NexaTextSecondaryBrush}"
                        FontSize="14"
                        TextWrapping="WrapWholeWords"
                        LineHeight="24" />
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button
                            Content="Batal"
                            MinWidth="150"
                            Height="40"
                            Padding="20,0"
                            CornerRadius="8"
                            Background="#141414"
                            BorderBrush="#38FFFFFF"
                            BorderThickness="1"
                            Foreground="{ThemeResource NexaTextPrimaryBrush}"
                            Click="LibraryRemoveConfirmCancel_Click" />
                        <Button
                            Content="Hapus Game"
                            MinWidth="180"
                            Height="40"
                            Padding="24,0"
                            CornerRadius="8"
                            Background="#F2F2F2"
                            BorderBrush="#F2F2F2"
                            BorderThickness="1"
                            Foreground="#000000"
                            Click="LibraryRemoveConfirmPrimary_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="LibraryRemoveResultOverlay"
            Grid.RowSpan="2"
            Visibility="Collapsed"
            Background="#B3000000"
            IsHitTestVisible="True">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="680"
                MaxWidth="980"
                Margin="18"
                CornerRadius="16"
                Background="#0A0A0A"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                Padding="28">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="LibraryRemoveResultTitleText"
                        Text="Remove Game Gagal"
                        Foreground="{ThemeResource NexaTextPrimaryBrush}"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="LibraryRemoveResultMessageText"
                        Foreground="{ThemeResource NexaTextSecondaryBrush}"
                        FontSize="14"
                        TextWrapping="WrapWholeWords"
                        LineHeight="24" />
                    <Button
                        Content="Mengerti"
                        HorizontalAlignment="Right"
                        MinWidth="180"
                        Height="40"
                        Padding="24,0"
                        CornerRadius="8"
                        Background="#F2F2F2"
                        BorderBrush="#F2F2F2"
                        BorderThickness="1"
                        Foreground="#000000"
                        Click="LibraryRemoveResultClose_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
