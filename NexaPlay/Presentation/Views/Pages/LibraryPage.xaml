<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="28,24,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header stats -->
        <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border CornerRadius="8" Padding="16,10"
                        Background="#208B7CF8"
                        BorderBrush="#408B7CF8" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F1;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16" Foreground="#8B7CF8"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}">
                            <Run Text="34"/>
                            <Run Text="Games in Library"
                                 Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                 FontWeight="Normal"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border CornerRadius="8" Padding="16,10"
                        Background="#1822C55E"
                        BorderBrush="#3022C55E" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE930;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16" Foreground="#22C55E"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource NexaTextPrimaryBrush}">
                            <Run Text="28"/>
                            <Run Text="Fixes Applied"
                                 Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                 FontWeight="Normal"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Library list -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel>

                    <!-- Library item 1 -->
                    <Grid Padding="20,16" MinHeight="72">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44"
                                CornerRadius="8">
                            <Image Source="https://cdn.cloudflare.steamstatic.com/steam/apps/1086940/capsule_231x87.jpg"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="3" Margin="14,0">
                            <TextBlock Text="Baldur's Gate 3"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource NexaTextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="RPG"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="·" FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="Fix applied 3 days ago"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                Background="#1822C55E"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE73E;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="10" Foreground="#22C55E"/>
                                <TextBlock Text="Fix Applied"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#22C55E"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="3"
                                Content="Remove Fix"
                                Height="34" CornerRadius="6"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                Background="#08FFFFFF"
                                Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                FontSize="12"
                                BorderBrush="#1E1E1E" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="#161616" Margin="20,0"/>

                    <!-- Library item 2 -->
                    <Grid Padding="20,16" MinHeight="72">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44"
                                CornerRadius="8">
                            <Image Source="https://cdn.cloudflare.steamstatic.com/steam/apps/2767030/capsule_231x87.jpg"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="3" Margin="14,0">
                            <TextBlock Text="Black Myth: Wukong"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource NexaTextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Action RPG"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="·" FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="Fix applied 1 week ago"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                Background="#1822C55E"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE73E;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="10" Foreground="#22C55E"/>
                                <TextBlock Text="Fix Applied"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#22C55E"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="3"
                                Content="Remove Fix"
                                Height="34" CornerRadius="6"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                Background="#08FFFFFF"
                                Foreground="{ThemeResource NexaTextSecondaryBrush}"
                                FontSize="12"
                                BorderBrush="#1E1E1E" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="#161616" Margin="20,0"/>

                    <!-- Library item 3 - no fix yet -->
                    <Grid Padding="20,16" MinHeight="72">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44"
                                CornerRadius="8">
                            <Image Source="https://cdn.cloudflare.steamstatic.com/steam/apps/1245620/capsule_231x87.jpg"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="3" Margin="14,0">
                            <TextBlock Text="Elden Ring"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource NexaTextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Action RPG"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="·" FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                                <TextBlock Text="Not fixed yet"
                                           FontSize="11"
                                           Foreground="{ThemeResource NexaTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                Background="#18F59E0B"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                            <TextBlock Text="Not Applied"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#F59E0B"/>
                        </Border>
                        <Button Grid.Column="3"
                                Content="Apply Fix"
                                Height="34" CornerRadius="6"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                Background="#8B7CF8"
                                Foreground="White"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
