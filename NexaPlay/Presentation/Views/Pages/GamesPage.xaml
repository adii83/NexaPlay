<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexaPlay.Presentation.Views.Pages.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="28,20,28,28" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Games Catalog"
                       FontSize="24"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Border Grid.Column="1"
                    CornerRadius="8"
                    Background="#FFFFFF08"
                    BorderBrush="#242424"
                    BorderThickness="1"
                    Padding="10,6">
                <TextBlock Text="Most Popular"
                           Foreground="{ThemeResource NexaTextMutedBrush}" />
            </Border>
        </Grid>

        <GridView Grid.Row="1"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  ItemContainerStyle="{StaticResource DefaultGridViewItemStyle}">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid ItemWidth="210" ItemHeight="250" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridViewItem>
                <Border CornerRadius="10"
                        Background="#161616"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Baldur's Gate 3" FontWeight="SemiBold" />
                        <TextBlock Text="RPG" Foreground="{ThemeResource NexaTextMutedBrush}" />
                        <TextBlock Text="Fix Available" Foreground="#22C55E" />
                    </StackPanel>
                </Border>
            </GridViewItem>

            <GridViewItem>
                <Border CornerRadius="10"
                        Background="#161616"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Cyberpunk 2077" FontWeight="SemiBold" />
                        <TextBlock Text="Action RPG" Foreground="{ThemeResource NexaTextMutedBrush}" />
                        <TextBlock Text="Fix Available" Foreground="#22C55E" />
                    </StackPanel>
                </Border>
            </GridViewItem>

            <GridViewItem>
                <Border CornerRadius="10"
                        Background="#161616"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Elden Ring" FontWeight="SemiBold" />
                        <TextBlock Text="Soulslike RPG" Foreground="{ThemeResource NexaTextMutedBrush}" />
                        <TextBlock Text="No Fix Needed" Foreground="#F59E0B" />
                    </StackPanel>
                </Border>
            </GridViewItem>
        </GridView>
    </Grid>
</Page>
