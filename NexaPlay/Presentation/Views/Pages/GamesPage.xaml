<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="NexaPlay.Presentation.Views.Pages.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NexaPlay.Core.Models"
    xmlns:local="using:NexaPlay.Presentation.Views.Pages"
    NavigationCacheMode="Required"
    mc:Ignorable="d"
    Background="#080808">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,16,20,0"
                Padding="16,14,16,12"
                CornerRadius="14"
                BorderBrush="#2CFFFFFF"
                BorderThickness="1"
                Background="#D10A0A0A">
            <StackPanel Spacing="10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{x:Bind ViewModel.ToggleFilterCommand}"
                            Height="38"
                            MinWidth="80"
                            Padding="12,0"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE71C;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="White" />
                            <TextBlock Text="Filter" FontWeight="Bold" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBox Grid.Column="1"
                             PlaceholderText="Search Games"
                             Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="42"
                             Background="#0D0D0D"
                             BorderBrush="#22FFFFFF"
                             BorderThickness="1"
                             CornerRadius="8"
                             FontSize="14"
                             Padding="14,8,14,4"
                             VerticalContentAlignment="Center"
                             PlaceholderForeground="#B8C6D8"
                             Foreground="{ThemeResource NexaTextPrimaryBrush}" />

                    <Button Grid.Column="2"
                            Command="{x:Bind ViewModel.SearchNowCommand}"
                            Height="38"
                            MinWidth="56"
                            MaxWidth="56"
                            Padding="0">
                        <FontIcon Glyph="&#xE721;"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="White"
                                  FontSize="15" />
                    </Button>

                </Grid>

                <TextBlock Margin="2,2,0,0"
                           Foreground="White"
                           FontSize="12">
                    <Run Text="Tips: cari akurat pakai AppID dari " />
                    <Hyperlink NavigateUri="https://steamdb.info/">SteamDB</Hyperlink>
                    <Run Text="." />
                </TextBlock>

            </StackPanel>
        </Border>

        <Border x:Name="FilterOverlay"
                Grid.RowSpan="2"
                Canvas.ZIndex="20"
                Margin="20,112,20,0"
                VerticalAlignment="Top"
                Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.IsFilterOpen), Mode=OneWay}"
                Background="#0A0A0A"
                BorderBrush="#2AFFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="FilterOverlayTranslate" Y="-8" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <Grid>
                    <TextBlock Text="Status Game"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Clear Filter"
                                Command="{x:Bind ViewModel.ClearFiltersCommand}"
                                Background="White" BorderThickness="0"
                                Foreground="Black"
                                FontSize="12"
                                FontWeight="SemiBold"
                                CornerRadius="4"
                                VerticalAlignment="Center" />
                        <Button Background="White"
                                BorderThickness="0"
                                Foreground="Black"
                                CornerRadius="4"
                                Padding="4"
                                Width="28" Height="28"
                                Command="{x:Bind ViewModel.ToggleFilterCommand}"
                                ToolTipService.ToolTip="Close Filter">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid Orientation="Horizontal"
                                      MaximumRowsOrColumns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <CheckBox Content="Standard"
                              MinWidth="165"
                              MaxWidth="220"
                              Margin="0,2,12,8"
                              IsChecked="{x:Bind ViewModel.FilterStandard, Mode=TwoWay}" />
                    <CheckBox Content="Premium"
                              MinWidth="165"
                              MaxWidth="220"
                              Margin="0,2,12,8"
                              IsChecked="{x:Bind ViewModel.FilterPremium, Mode=TwoWay}" />
                    <CheckBox Content="Denuvo"
                              MinWidth="165"
                              MaxWidth="220"
                              Margin="0,2,12,8"
                              IsChecked="{x:Bind ViewModel.FilterDenuvo, Mode=TwoWay}" />
                    <CheckBox Content="Non Denuvo"
                              MinWidth="165"
                              MaxWidth="220"
                              Margin="0,2,12,8"
                              IsChecked="{x:Bind ViewModel.FilterNonDenuvo, Mode=TwoWay}" />
                </ItemsControl>

                <TextBlock Text="Genre"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource NexaTextPrimaryBrush}" />

                <ItemsControl x:Name="GenreItemsControl" ItemsSource="{x:Bind ViewModel.GenreMaster, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid Orientation="Horizontal"
                                      MaximumRowsOrColumns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <CheckBox
                                Content="{x:Bind}"
                                MinWidth="165"
                                MaxWidth="220"
                                Margin="0,2,12,8"
                                Tag="{x:Bind}"
                                Checked="OnGenreChecked"
                                Unchecked="OnGenreUnchecked" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ProgressBar Grid.Row="0"
                         IsIndeterminate="True"
                         Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                         VerticalAlignment="Top"
                         Height="2"
                         Margin="20,8,20,0" />

            <GridView x:Name="GamesGrid"
                      Grid.Row="0"
                      SizeChanged="GamesGrid_SizeChanged"
                      Margin="20,14,20,10"
                      ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                      IsItemClickEnabled="False"
                      SelectionMode="None"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="8" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:FixEntry">
                        <Button Style="{StaticResource PopularGameCardStyle}"
                                Click="OnGameCardClicked"
                                PointerEntered="GameCard_PointerEntered"
                                PointerExited="GameCard_PointerExited"
                                Tag="{x:Bind AppId}"
                                HorizontalAlignment="Stretch">
                            <Grid CornerRadius="12" BorderBrush="{ThemeResource NexaCardBorderBrush}" BorderThickness="1">
                                <Border CornerRadius="12">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{x:Bind local:GamesPage.ToImageSource(PosterUrl), Mode=OneTime}" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                                <Border CornerRadius="12"
                                        Background="#101418"
                                        Visibility="{x:Bind local:GamesPage.InverseBoolToVis(HasPopularCover), Mode=OneTime}">
                                    <TextBlock Text="NO CONTENT"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#CCFFFFFF"
                                               CharacterSpacing="120" />
                                </Border>
                                <Border CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#00000000" Offset="0.2" />
                                            <GradientStop Color="#E6000000" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Spacing="8">
                                    <Grid>
                                        <Border Visibility="{x:Bind local:GamesPage.BoolToVis(IsPremium)}"
                                                Background="{ThemeResource NexaTextPrimaryBrush}"
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="PREMIUM" FontSize="10" FontWeight="Bold" Foreground="#000000" />
                                        </Border>
                                        <Border Visibility="{x:Bind local:GamesPage.InverseBoolToVis(IsPremium)}"
                                                Background="#000000"
                                                BorderBrush="#4DFFFFFF" BorderThickness="1"
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="STANDARD" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource NexaTextPrimaryBrush}" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                        Visibility="{x:Bind local:GamesPage.BoolToVis(HasDenuvo)}"
                                        Background="#EAB308"
                                        BorderBrush="#FEF08A" BorderThickness="1.5"
                                        CornerRadius="4" Padding="6,4"
                                        Loaded="DenuvoBadge_Loaded">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="10" Foreground="#FFFFFF" FontWeight="Bold" />
                                        <TextBlock Text="DENUVO" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,1,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="HoverTitleLayer"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,1"
                                        Padding="12,30,12,14"
                                        Opacity="0"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="14" />
                                    </Border.RenderTransform>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#00000000" Offset="0.0" />
                                            <GradientStop Color="#99000000" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="{x:Bind Title}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Bottom"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource NexaTextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </GridView.ItemTemplate>
                <GridView.Footer>
                    <Border Margin="0,8,0,16"
                            Background="#0A0A0A"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,8"
                            HorizontalAlignment="Center"
                            Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.ShowPager), Mode=OneWay}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Prev"
                                    Command="{x:Bind ViewModel.PreviousPageCommand}"
                                    Background="#121212"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    IsEnabled="{x:Bind ViewModel.CanGoPrevious, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Content="{x:Bind ViewModel.PageSlot1, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot1, Mode=OneWay}"
                                    Background="{x:Bind local:GamesPage.PageButtonBackground(ViewModel.IsPage1Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:GamesPage.PageButtonForeground(ViewModel.IsPage1Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.ShowPage1), Mode=OneWay}" />
                            <Button Grid.Column="2"
                                    Content="{x:Bind ViewModel.PageSlot2, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot2, Mode=OneWay}"
                                    Background="{x:Bind local:GamesPage.PageButtonBackground(ViewModel.IsPage2Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:GamesPage.PageButtonForeground(ViewModel.IsPage2Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.ShowPage2), Mode=OneWay}" />
                            <Button Grid.Column="3"
                                    Content="{x:Bind ViewModel.PageSlot3, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.GoToPageCommand}"
                                    CommandParameter="{x:Bind ViewModel.PageSlot3, Mode=OneWay}"
                                    Background="{x:Bind local:GamesPage.PageButtonBackground(ViewModel.IsPage3Selected), Mode=OneWay}"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Foreground="{x:Bind local:GamesPage.PageButtonForeground(ViewModel.IsPage3Selected), Mode=OneWay}"
                                    Visibility="{x:Bind local:GamesPage.BoolToVis(ViewModel.ShowPage3), Mode=OneWay}" />
                            <Button Grid.Column="4"
                                    Content="Next"
                                    Command="{x:Bind ViewModel.NextPageCommand}"
                                    Background="#121212"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" />
                        </Grid>
                    </Border>
                </GridView.Footer>
            </GridView>
        </Grid>
    </Grid>
</Page>
